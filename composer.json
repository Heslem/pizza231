{
    "name": "kkt/pizza231",
    "description": "Пиццерия на PHP с использованием MVC",
    "type": "project",
    "require": {
        "php": ">=7.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Test\\": "tests/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\": "src/",
            "Test\\": "tests/"
        }
    },    
    "scripts": {
        "start": "php -S localhost:8000"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    }
}
